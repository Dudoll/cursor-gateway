{
  "name": "@cursor-gateway/windows-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "pair:runner": "tsx src/pair.ts runner",
    "pair:client": "tsx src/pair.ts client",
    "pair:list": "tsx src/pair.ts list-clients",
    "pair:revoke": "tsx src/pair.ts revoke-client",
    "start": "node dist/index.js",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@cursor-gateway/e2ee": "file:../../packages/e2ee",
    "@cursor-gateway/shared": "file:../../packages/shared",
    "@cursor/sdk": "^1.0.23",
    "nodemailer": "^7.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
