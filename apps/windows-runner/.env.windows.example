GATEWAY_URL=https://gateway.example.com
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
RUNNER_ID=windows-main
RUNNER_SHARED_SECRET=replace-with-the-same-secret-used-by-the-vps
RUNNER_WORKSPACES=C:\Workspaces\project1;D:\Workspaces\project2
RUNNER_POLL_INTERVAL_MS=2000
RUNNER_MAX_CONCURRENT_JOBS=3
RUNNER_JOB_TIMEOUT_MS=1800000
RUNNER_CANCEL_GRACE_MS=10000
RUNNER_VERSION=0.1.0
RUNNER_E2EE_ENABLED=true
RUNNER_LEGACY_ENABLED=false
# Leave blank to use %USERPROFILE%\.cursor-gateway\runner-e2ee-state.dat
RUNNER_E2EE_STATE_FILE=
# Tests only; production Windows runners must use DPAPI.
RUNNER_E2EE_ALLOW_INSECURE_DEV_STORAGE=false
CURSOR_API_KEY=
DEFAULT_MODEL=auto
