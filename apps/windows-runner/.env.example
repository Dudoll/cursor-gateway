# Cursor Gateway runner configuration.
# scripts/setup-runner.sh creates a copy of this file as ".env" on first run.
# Fill in the values below, then run the setup script again.

# Public URL of your gateway (the server/VPS deployment).
GATEWAY_URL=https://gateway.example.com

# Shared secret used to authenticate the runner with the server.
# Must be identical to RUNNER_SHARED_SECRET on the server, 32+ characters.
RUNNER_SHARED_SECRET=replace-with-the-same-secret-used-by-the-server

# Directories the agent may read/write, separated by ";".
# Use absolute paths that exist on THIS machine.
# Linux/WSL example: /home/you/projects
# (Windows-style paths like D:\work are auto-mapped to /mnt/d/work on WSL.)
RUNNER_WORKSPACES=/home/you/projects

# Your Cursor API key (starts with crsr_ or cursor_). Create one at https://cursor.com.
CURSOR_API_KEY=

# Label shown for this runner in the dashboard.
RUNNER_ID=main-runner

# Default model to use when a request does not specify one.
DEFAULT_MODEL=auto

# Advanced settings (safe defaults).
RUNNER_POLL_INTERVAL_MS=2000
RUNNER_MAX_CONCURRENT_JOBS=3

# Only required if the gateway is protected by Cloudflare Access.
# Leave blank otherwise.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
