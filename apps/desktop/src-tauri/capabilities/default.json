{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main Secure Web window plus the Cloudflare Access bridge window used to carry Access cookies for API calls.",
  "windows": ["main", "access-bridge", "passkey-bridge"],
  "remote": {
    "urls": [
      "https://cs.joelzt.org/*",
      "https://*.joelzt.org/*",
      "http://127.0.0.1:*/*",
      "http://localhost:*/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-webview-close",
    "core:webview:allow-webview-show",
    "core:webview:allow-webview-hide",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "allow-desktop-app-version",
    "allow-desktop-diagnostics",
    "allow-desktop-access-ensure",
    "allow-desktop-access-show",
    "allow-desktop-bridge-fetch",
    "allow-desktop-perform-passkey",
    "allow-desktop-install-update"
  ]
}
