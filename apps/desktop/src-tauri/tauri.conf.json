{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cursor Gateway",
  "version": "0.1.1",
  "identifier": "org.joelzt.cursorgateway.desktop",
  "build": {
    "frontendDist": "../../secure-web/dist",
    "devUrl": "http://127.0.0.1:5174",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cursor Gateway — 加密对话",
        "label": "main",
        "width": 1120,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://secure.joelzt.org https://cs.joelzt.org https://*.joelzt.org; frame-src 'self'; object-src 'none'; base-uri 'self'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
