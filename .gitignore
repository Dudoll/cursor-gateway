!scripts/csapi/trust/csapi-trust-root-public.json
!scripts/csapi/trust/extension-ed25519.pub.pem
!scripts/csapi/trust/desktop-ed25519.pub.pem
!scripts/csapi/trust/desktop-minisign.pub

