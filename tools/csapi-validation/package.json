{
  "name": "@cursor-gateway/csapi-validation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Strict black-box CSAPI/Hermes acceptance validator",
  "scripts": {
    "accept": "tsx src/cli.ts accept",
    "long": "tsx src/cli.ts long",
    "observe": "tsx src/cli.ts observe",
    "test": "tsx --test test/*.test.ts",
    "format": "node scripts/format.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run format && npm run lint && npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
