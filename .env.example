# Public domain (your gateway HTTPS origin)
PUBLIC_ORIGIN=https://gateway.example.com

# Server
NODE_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
JWT_SECRET=replace-with-at-least-32-random-bytes

# Postgres
POSTGRES_USER=cursor_gateway
POSTGRES_PASSWORD=replace-with-database-password
POSTGRES_DB=cursor_gateway
DATABASE_URL=postgres://cursor_gateway:replace-with-database-password@postgres:5432/cursor_gateway
REDIS_URL=redis://redis:6379

# Cloudflare Access
# Comma-separated allowlist. Leave empty to allow every identity accepted by
# the Cloudflare Access policy. The app still requires Access identity headers.
ALLOWED_EMAILS=you@example.com
ALLOWED_CLOUDFLARE_AUD=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
TELEGRAM_ALLOWED_USER_IDS=

# Runner registration
RUNNER_SHARED_SECRET=replace-with-different-random-secret
AUTOMATION_SHARED_SECRET=
HERMES_RUNNER_SHARED_SECRET=
RUNNER_REQUIRE_APPROVAL=false
RUNNER_MAX_CONCURRENT_JOBS=3
# Reject plaintext Web chat/Memory after the secure extension is deployed.
# Keep false until the extension is installed and E2EE_EXTENSION_ORIGINS is set.
E2EE_REQUIRED_FOR_WEB=true
# Comma-separated signed extension origins. Stable unpacked ID for this repo:
# chrome-extension://oicmfijjdbjkjhnljcjhnojpeiobhefe
E2EE_EXTENSION_ORIGINS=
# Independent Secure Web PWA origin (Cloudflare Pages / static HTTPS).
# CORS + pairing secureOrigin checks. See docs/secure-web-e2ee.md.
SECURE_CLIENT_ORIGIN=
# Comma-separated CS (apps/web) origins allowed to receive Runner-signed
# one-time CS device auth grants via Secure redirect. Example:
# WEB_E2EE_RETURN_ORIGINS=https://cs.joelzt.org
WEB_E2EE_RETURN_ORIGINS=
E2EE_PAIRING_TTL_SECONDS=900
# Short TTL for CS→Secure one-time device authorization packages.
E2EE_CS_AUTH_TTL_SECONDS=300
# Offline trust roots (server side) for verifying Runner identity certificates
# on passkey/recovery/device-approval acks and cs-auth grants. Provide either
# an inline JSON array of E2eeTrustRootPublic or a file path.
E2EE_TRUST_ROOTS_JSON=
E2EE_TRUST_ROOTS_FILE=
E2EE_PASSKEY_PAIRING_TTL_SECONDS=300
E2EE_DEVICE_APPROVAL_TTL_SECONDS=600
E2EE_RECOVERY_PAIRING_TTL_SECONDS=1800
# Optional. Cloudflare Access team domain for CS / Secure 「退出 Access」链接.
# Example: https://yourteam.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=
WEB_DEFAULT_MODEL=auto
REPORT_MODEL_ID=
REPORT_WORKSPACE_ID=

# Cursor SDK credentials used only on the Windows runner
CURSOR_API_KEY=
DEFAULT_MODEL=auto

# Windows runner
GATEWAY_URL=https://gateway.example.com
RUNNER_ID=windows-main
RUNNER_WORKSPACES=C:\\Workspaces\\project1;D:\\Workspaces\\project2
RUNNER_POLL_INTERVAL_MS=2000
RUNNER_VERSION=0.1.0
RUNNER_E2EE_ENABLED=true
RUNNER_LEGACY_ENABLED=false
# Defaults to %USERPROFILE%\\.cursor-gateway\\runner-e2ee-state.dat
RUNNER_E2EE_STATE_FILE=
# Never enable outside disposable non-Windows development tests.
RUNNER_E2EE_ALLOW_INSECURE_DEV_STORAGE=false
# Offline trust root / Runner identity certificate (see docs/trust-root-rotation.md)
RUNNER_IDENTITY_CERT_FILE=
E2EE_TRUST_ROOTS_FILE=
# Passkey (WebAuthn) pairing
RUNNER_WEBAUTHN_ENABLED=false
WEBAUTHN_RP_ID=secure.joelzt.org
WEBAUTHN_RP_NAME=Cursor Gateway Secure
WEBAUTHN_ORIGINS=
WEBAUTHN_CHALLENGE_TTL_SECONDS=300
DEVICE_APPROVAL_TTL_SECONDS=600
RECOVERY_TTL_SECONDS=1800

# Magic-link pairing mail (Runner). See docs/pairing-mail.md.
# Real pairing recipient = CF Access user email from claim-start (not PAIRING_MAIL_TO).
# PAIRING_MAIL_MODE=log
# PAIRING_MAIL_FROM=no-reply@piallera.com
# PAIRING_MAIL_FROM_NAME=Piallera Secure
# MAIL_API_PROVIDER=resend
# MAIL_API_KEY=
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=
# PAIRING_MAIL_TO=  # test-mail script only
