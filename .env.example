# Public domain (your gateway HTTPS origin)
PUBLIC_ORIGIN=https://gateway.example.com

# Server
NODE_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
JWT_SECRET=replace-with-at-least-32-random-bytes

# Postgres
POSTGRES_USER=cursor_gateway
POSTGRES_PASSWORD=replace-with-database-password
POSTGRES_DB=cursor_gateway
DATABASE_URL=postgres://cursor_gateway:replace-with-database-password@postgres:5432/cursor_gateway
REDIS_URL=redis://redis:6379

# Cloudflare Access
# Comma-separated allowlist. Leave empty to allow every identity accepted by
# the Cloudflare Access policy. The app still requires Access identity headers.
ALLOWED_EMAILS=you@example.com
ALLOWED_CLOUDFLARE_AUD=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
TELEGRAM_ALLOWED_USER_IDS=

# Runner registration
RUNNER_SHARED_SECRET=replace-with-different-random-secret
AUTOMATION_SHARED_SECRET=
HERMES_RUNNER_SHARED_SECRET=
RUNNER_REQUIRE_APPROVAL=false
RUNNER_MAX_CONCURRENT_JOBS=3
WEB_DEFAULT_MODEL=auto
REPORT_MODEL_ID=
REPORT_WORKSPACE_ID=
PUBLIC_REPORTS=false

# Cursor SDK credentials used only on the Windows runner
CURSOR_API_KEY=
DEFAULT_MODEL=auto

# Windows runner
GATEWAY_URL=https://gateway.example.com
RUNNER_ID=windows-main
RUNNER_WORKSPACES=C:\\Workspaces\\project1;D:\\Workspaces\\project2
RUNNER_POLL_INTERVAL_MS=2000
